PG_HOST=database
PG_PORT=5432
PG_PASSWORD=supersecurepassword
PG_USER=ticketa
PG_DATABASE=ticketa
# Pro externí/managed databázi nastavte verify-full
PG_SSLMODE=disable
LOG_LEVEL=debug
# Nastavte true při nasazení za HTTPS (Secure flag na session cookie)
COOKIE_SECURE=false
# SMTP — pokud SMTP_HOST není nastaven, odesílání emailů je vypnuto
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret
SMTP_FROM=ticketa@example.com
